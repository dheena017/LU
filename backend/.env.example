# Production Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to GitHub

# Database Connection (from Supabase)
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-random-secret-key-here-minimum-32-characters

# Allowed Frontend Origins (add all deploying to)
CORS_ORIGINS=https://your-site.netlify.app,http://localhost:5173

# Server Port (Render/Railway will override this)
PORT=5000

# Environment
NODE_ENV=production

# Frontend Base URL (for password reset links)
FRONTEND_URL=http://localhost:5173

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dheenadayalan627@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Kalvium LU Tracker <your-email@gmail.com>"
